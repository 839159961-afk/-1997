{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a parent or child user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "username": { "type": "string", "description": "Unique username for login." },
        "displayName": { "type": "string", "description": "User's display name." },
        "email": { "type": "string", "description": "User's email address (internal alias)." },
        "role": { "type": "string", "enum": ["parent", "child"], "description": "User's role." },
        "parentId": { "type": "string", "description": "The UID of the parent if the user is a child." },
        "inviteCode": { "type": "string", "description": "Invitation code generated by parents." },
        "balance": { "type": "number", "description": "Virtual coins balance." },
        "pocketMoney": { "type": "number", "description": "Real pocket money balance." },
        "avatar": { "type": "string", "description": "Avatar URL." }
      },
      "required": ["uid", "username", "displayName", "role"]
    },
    "Pet": {
      "title": "Pet",
      "description": "Represents a child's virtual pet.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique pet ID." },
        "ownerId": { "type": "string", "description": "The UID of the child who owns the pet." },
        "type": { "type": "string", "enum": ["cat", "dog", "dino", "elf"], "description": "Pet species." },
        "name": { "type": "string", "description": "Pet's name." },
        "growth": { "type": "number", "description": "Growth value (0-1000)." },
        "hunger": { "type": "number", "description": "Hunger level (0-100)." },
        "cleanliness": { "type": "number", "description": "Cleanliness level (0-100)." },
        "happiness": { "type": "number", "description": "Happiness level (0-100)." },
        "health": { "type": "number", "description": "Health level (0-100)." },
        "level": { "type": "number", "description": "Pet's level." },
        "skinId": { "type": "string", "description": "Current skin ID." }
      },
      "required": ["ownerId", "type", "name"]
    },
    "Task": {
      "title": "Task",
      "description": "Represents a habit task created by a parent.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique task ID." },
        "parentId": { "type": "string", "description": "The UID of the parent who created the task." },
        "title": { "type": "string", "description": "Task title." },
        "description": { "type": "string", "description": "Task description." },
        "coins": { "type": "number", "description": "Virtual coins reward." },
        "money": { "type": "number", "description": "Real money reward." },
        "ageGroup": { "type": "string", "enum": ["3-6", "7-9", "10-12"], "description": "Target age group." },
        "type": { "type": "string", "enum": ["daily", "weekly", "one-time"], "description": "Task frequency." }
      },
      "required": ["parentId", "title", "coins", "money"]
    },
    "Checkin": {
      "title": "Checkin",
      "description": "Represents a task completion submission by a child.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique checkin ID." },
        "childId": { "type": "string", "description": "The UID of the child who checked in." },
        "parentId": { "type": "string", "description": "The UID of the parent of the child." },
        "taskId": { "type": "string", "description": "The ID of the task." },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Submission status." },
        "photoUrl": { "type": "string", "description": "Photo proof URL." },
        "voiceUrl": { "type": "string", "description": "Voice proof URL." },
        "comment": { "type": "string", "description": "Child's comment." },
        "timestamp": { "type": "string", "format": "date-time", "description": "Submission time." },
        "parentComment": { "type": "string", "description": "Parent's feedback." }
      },
      "required": ["childId", "parentId", "taskId", "status", "timestamp"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Represents a financial or virtual currency transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique transaction ID." },
        "userId": { "type": "string", "description": "The UID of the user involved." },
        "amount": { "type": "number", "description": "Transaction amount." },
        "type": { "type": "string", "enum": ["coin", "money"], "description": "Currency type." },
        "description": { "type": "string", "description": "Transaction description." },
        "timestamp": { "type": "string", "format": "date-time", "description": "Transaction time." }
      },
      "required": ["userId", "amount", "type", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles." },
    "/pets/{petId}": { "schema": "Pet", "description": "Virtual pets." },
    "/tasks/{taskId}": { "schema": "Task", "description": "Parent-defined tasks." },
    "/checkins/{checkinId}": { "schema": "Checkin", "description": "Task check-in submissions." },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Currency transactions." }
  }
}
